
#II. Generate & Export the Cert
# Step 1 — Create a self-signed cert in your personal store
$cert = New-SelfSignedCertificate -CertStoreLocation "Cert:\CurrentUser\My" `
    -Subject "CN=xxxyyy" `
    -KeyExportPolicy Exportable `
    -KeySpec Signature `
    -NotAfter (Get-Date).AddYears(2)

# Step 2 — Set the password (do this BEFORE exporting)
$pwd = ConvertTo-SecureString -String "type-in-PASSWORD" -Force -AsPlainText

# Step 3 — Export the private key (.pfx)
Export-PfxCertificate -Cert $cert `
    -FilePath "$env:USERPROFILE\Documents\xxx.pfx" `
    -Password $pwd

# Step 4 — Export the public key (.cer)
Export-Certificate -Cert $cert `
    -FilePath "$env:USERPROFILE\Documents\yyy.cer"
